        "Z2"}], "+", 
       RowBox[{"Z3", ".", 
        RowBox[{"KroneckerProduct", "[", 
         RowBox[{
          RowBox[{"Conjugate", "[", "psi0", "]"}], ",", "psi0"}], "]"}], ".", 
        "Z3"}]}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fid", "=", 
   RowBox[{
    RowBox[{"Conjugate", "[", "psitarget", "]"}], ".", "rho0", ".", 
    "psitarget"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fidlist", "=", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"0", ",", "fid"}], "}"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rho", "=", "rho0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"j", "=", "1"}], ",", 
    RowBox[{"j", "<=", "noiter"}], ",", 
    RowBox[{"j", "=", 
     RowBox[{"j", "+", "1"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"rhop", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"rho", "+", 
         RowBox[{"rho", ".", "rho"}]}], ")"}], "/", "2"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"prob", "=", 
      RowBox[{"Tr", "[", "rhop", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rho", "=", 
      RowBox[{"rhop", "/", "prob"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"fid", "=", 
