Cell[BoxData[{
 RowBox[{
  RowBox[{"Np", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dim", "=", 
   RowBox[{"2", "^", "Np"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"noiter", "=", "40"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"psitarget", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", 
     FractionBox["1", 
      SqrtBox["3"]], ",", 
     FractionBox["1", 
      SqrtBox["3"]], ",", "0", ",", 
     FractionBox["1", 
      SqrtBox["3"]], ",", "0", ",", "0", ",", "0"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"psitarget", "=", 
   RowBox[{"Normalize", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "1", ",", "dim"}], "}"}]}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"psi0", "=", "psitarget"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Idbig", "=", 
   RowBox[{"IdentityMatrix", "[", "dim", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"p", "=", "0.2"}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
